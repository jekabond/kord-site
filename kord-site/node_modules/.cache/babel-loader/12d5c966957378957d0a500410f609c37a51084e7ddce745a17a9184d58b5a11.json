/>\n            УКРАЇНИ\n          </h2>\n          <p className=\"about__desc\">\n            Другий загін спеціальних дій став стати легендою. Лише згадка про нас\n            робить велику нагоду перед ворогу. Наш ковер — успішні операції.\n          </p>\n          <p className=\"about__desc\">\n            У нашому підрозділі можна знайти практично будь-яку бойову\n            спеціальність: розвідник, сапер, снайпер, водолаз, шкіпер та інші.\n          </p>\n          <a href=\"#specializations\" className=\"about__link\">\n            Підрозділ активних дій →\n          </a>\n        </div>\n\n        <div className=\"about__image\">\n          <div className=\"about__image-wrap\">\n            <img\n              src=\"https://images.unsplash.com/photo-1614935151651-0bea6508db6b?w=800&q=80\"\n              alt=\"Бійці КОРД\"\n            />\n            <div className=\"about__image-overlay\" />\n          </div>\n          <div className=\"about__image-badge\">\n            <span>ПІДРОЗДІЛ</span>\n            <span>АКТИВНИХ ДІЙ</span>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n};\n\nexport default About;\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,KAAM,OAAO,CACzB,MAAO,aAAa,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAErB,KAAM,CAAAC,KAAK,CAAGA,CAAA,GAAM,CAClB,mBACEH,IAAA,YAASI,SAAS,CAAC,OAAO,CAACC,EAAE,CAAC,OAAO,CAAAC,QAAA,cACnCJ,KAAA,QAAKE,SAAS,CAAC,wBAAwB,CAAAE,QAAA,eACrCJ,KAAA,QAAKE,SAAS,CAAC,aAAa,CAAAE,QAAA,eAC1BN,IAAA,MAAGI,SAAS,CAAC,eAAe,CAAAE,QAAA,CAAC,2EAAa,CAAG,CAAC,cAC9CJ,KAAA,OAAIE,SAAS,CAAC,cAAc,CAAAE,QAAA,EAAC,gCACtB,cAAAN,IAAA,QAAK,CAAC,kCACL,cAAAA,IAAA,QAAK,CAAC,6CAEd,EAAI,CAAC,cACLA,IAAA,MAAGI,SAAS,CAAC,aAAa,CAAAE,QAAA,CAAC,mrBAG3B,CAAG,CAAC,cACJN,IAAA,MAAGI,SAAS,CAAC,aAAa,CAAAE,QAAA,CAAC,koBAG3B,CAAG,CAAC,cACJN,IAAA,MAAGO,IAAI,CAAC,kBAAkB,CAACH,SAAS,CAAC,aAAa,CAAAE,QAAA,CAAC,mIAEnD,CAAG,CAAC,EACD,CAAC,cAENJ,KAAA,QAAKE,SAAS,CAAC,cAAc,CAAAE,QAAA,eAC3BJ,KAAA,QAAKE,SAAS,CAAC,mBAAmB,CAAAE,QAAA,eAChCN,IAAA,QACEQ,GAAG,CA